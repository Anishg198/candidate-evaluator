# ── Database ──────────────────────────────────────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/hcl_module3

# ── LiveKit (self-hosted, no account or credit card required) ─────────────────
# Internal Docker URL used by the backend to call the LiveKit API
LIVEKIT_API_URL=http://livekit:7880
# API key/secret set by LiveKit --dev mode (do not change for local dev)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Public WebSocket URL that browsers connect to
LIVEKIT_PUBLIC_WS_URL=ws://localhost:7880

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
